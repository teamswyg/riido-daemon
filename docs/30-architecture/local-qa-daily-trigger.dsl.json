{
  "schema_version": "riido-qa-trigger-dsl.v1",
  "id": "daily-evidence-sweep",
  "name": "Daily Evidence Sweep",
  "common_name": "하루 한 번 증적 순회",
  "cadence": "daily",
  "clock": "local",
  "default_time": "09:00",
  "entrypoint": "go run ./tools/localqarunner",
  "freshness_window": "24h",
  "evidence": [
    ".riido-local/evidence/ai-agent-product-acceptance.json",
    ".riido-local/evidence/local-qa-coverage.json",
    ".riido-local/evidence/local-qa-run.json",
    ".riido-local/evidence/local-qa-schedule.json",
    ".riido-local/dashboard/index.html"
  ],
  "closed_loop": [
    "observe figma and contract intent",
    "run daemon-owned contract probes",
    "write evidence with expires_at",
    "render dashboard coverage rows",
    "publish latest and timestamped artifacts",
    "show stale rows after freshness expiry"
  ],
  "reject_if": [
    "no evidence file is written",
    "no expires_at is recorded",
    "no dashboard or coverage handoff exists",
    "the schedule cannot prove the named trigger"
  ]
}
