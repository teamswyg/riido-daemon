{
  "schema_version": "riido-daemon-ci-evidence.v1",
  "id": "daemon-ci-evidence",
  "loop_source": "docs/30-architecture/loop-engineering/ci-evidence.riido.json",
  "workflows": [
    {
      "id": "ci",
      "workflow": ".github/workflows/ci.yml",
      "evidence_artifact": "ci-evidence",
      "required_commands": [
        "go list -m all",
        "go test ./..."
      ]
    },
    {
      "id": "go-ci",
      "workflow": ".github/workflows/go-ci.yml",
      "evidence_artifact": "go-ci-evidence",
      "required_commands": [
        "go mod download",
        "go install github.com/golangci/golangci-lint/v2/cmd/golangci-lint@v2.12.2",
        "golangci-lint run ./... --timeout=5m",
        "go test ./..."
      ]
    }
  ]
}
