{
  "schema_version": "riido-loop-registry.v1",
  "id": "daemon-loop-registry",
  "title": "Daemon Loop Registry",
  "generated_doc": "docs/30-architecture/loop-registry.md",
  "workflow": ".github/workflows/loop-registry.yml",
  "evidence_artifact": "loop-registry",
  "precommit_hook": "loop-registry",
  "command": "go run ./tools/loopregistry -check-doc",
  "loop": {
    "observation": "QA, workflow, and executable-knowledge evidence existed, but the relationship between loops, business claims, code paths, tests, docs, and evidence was still inferred by humans.",
    "hypothesis": "A Loop Registry manifest can make loop ownership and business-claim bindings executable so an agent does not need to read prose before changing semantically bound files.",
    "execute": "Verify loop entries, evidence-graph closure, claim file anchors, verifier source tokens, CI wiring, pre-commit wiring, generated-doc freshness, and optional changed-file co-change constraints.",
    "evaluate": "The verifier fails when a loop omits observe/verify/evidence/freshness/fail conditions, when a claim has no code/doc/test/evidence binding, or when a claim-bound runtime file changes without bound proof changing too.",
    "retrospective": "Harnesses can keep discovering failures while the registry decides which discoveries have become closed loops and which files must move together."
  },
  "loops": [
    {
      "id": "local-qa-gap-to-candidate",
      "owner": "tools/localproductacceptance",
      "kind": "harness-to-closed-loop-intake",
      "observes": ["skipped scenarios", "partial scenarios", "failed scenarios", "inferred execution ids"],
      "verifies": ["closed_loop_candidates are emitted", "candidate count is visible in JSON evidence", "each candidate carries an evidence_graph", "each candidate declares required_next_artifacts", "local QA run evidence rolls candidates up"],
      "evidence": [".riido-local/evidence/ai-agent-product-acceptance.json", "local-qa-runner artifact"],
      "expires_after": "24h",
      "fails_when": ["closed_loop_candidates missing", "required_next_artifacts missing", "inferred execution hidden", "evidence gap silently passes"],
      "evidence_graph": {
        "observation": "local QA scenarios can be skipped or inferred without creating follow-up work.",
        "hypothesis": "Every skipped, partial, failed, or inferred observation should become a closed_loop_candidate.",
        "change": "evidence_gap_candidates derives candidates from local QA scenario outcomes.",
        "verifier": "TestEvidenceGapScenarioPromotesInferredExecutionLoops",
        "evidence": "local.qa.evidence_gap_candidates",
        "decision": "partial status is expected while candidates remain.",
        "next_loop": "promote one candidate into a system-owned verifier."
      }
    },
    {
      "id": "local-qa-evidence-expiry-gate",
      "owner": "tools/localqarunner",
      "kind": "closed-loop",
      "observes": ["coverage rows", "expires_at", "deployment gate"],
      "verifies": ["expired coverage rows block deployment", "strict release gate fails on blocked deployment gate", "fresh coverage rows remain deployable"],
      "evidence": [".riido-local/evidence/local-qa-run.json", ".riido-local/evidence/local-qa-coverage.json"],
      "expires_after": "24h",
      "fails_when": ["expired evidence is treated as green", "deployment gate omits coverage_evidence_expired", "strict coverage ignores a blocked deployment gate"],
      "evidence_graph": {
        "observation": "coverage evidence can remain passed after its source rows have expired.",
        "hypothesis": "The release gate should block expired local QA rows even when the previous coverage summary was passed.",
        "change": "deployment gate counts expired coverage rows and emits coverage_evidence_expired.",
        "verifier": "TestBuildDeploymentGateBlocksExpiredCoverageRows",
        "evidence": "deployment_gate.blockers[].code=coverage_evidence_expired",
        "decision": "expired evidence requires a new QA run before deployment.",
        "next_loop": "connect launchd schedule evidence to automatic rerun confirmation."
      }
    },
    {
      "id": "local-qa-candidate-decision",
      "owner": "tools/localqacandidatedecision",
      "kind": "closed-loop",
      "observes": ["local QA closed_loop_candidates", "required_next_artifacts", "decision records"],
      "verifies": ["out/local-qa-run.json candidates have decisions", "decision next_artifact is required by each candidate", "orphan decision records fail"],
      "evidence": ["local-qa-candidate-decision", "decision_artifacts", "candidate_count"],
      "expires_after": "24h",
      "fails_when": ["candidate decision missing", "decision references missing candidate", "next_artifact is not required", "candidate input omitted"],
      "evidence_graph": {
        "observation": "Local QA can produce closed-loop candidates while priority and ownership remain implicit.",
        "hypothesis": "A candidate decision verifier can force every current local QA candidate to bind owner, priority, disposition, next loop, and next artifact.",
        "change": "localqacandidatedecision consumes local-qa-run evidence inside the local-qa-runner workflow.",
        "verifier": "TestCandidateDecisionCoversLocalQACandidate",
        "evidence": "local-qa-candidate-decision",
        "decision": "Local QA candidate decisions are executable evidence, not a passive dashboard list.",
        "next_loop": "promote triage_required decisions into claim-bound verifiers."
      }
    },
    {
      "id": "qa-system-inference-surfacing",
      "owner": "tools/localproductacceptance",
      "kind": "systematization-audit",
      "observes": ["qa-system DSL", "execution_inventory", "generated QA mirrors"],
      "verifies": ["inference_required_count", "inference_required_ids", "generated drift checks"],
      "evidence": [".riido-local/evidence/ai-agent-product-acceptance.json"],
      "expires_after": "24h",
      "fails_when": ["inferred execution is counted as green", "generated artifacts drift", "pre-commit generation is absent"],
      "evidence_graph": {
        "observation": "some QA actions still require human or Codex inference.",
        "hypothesis": "Counting inferred execution explicitly prevents false green QA evidence.",
        "change": "qaSystemScenario marks inferred execution as partial evidence.",
        "verifier": "TestQASystemExecutionInventoryCounts",
        "evidence": "local.qa.dsl_system_audit",
        "decision": "remaining inferred ids are surfaced as candidates.",
        "next_loop": "replace inferred entries with system-owned commands."
      }
    },
    {
      "id": "intent-clarification-needs-input",
      "owner": "internal/agentbridge/controlplane/saasplane",
      "kind": "closed-loop",
      "observes": ["provider completed output", "clarification question markers", "AgentEventRequest metadata"],
      "verifies": ["assignment_result_status=needs_input is emitted", "assignment is not reported completed", "events endpoint shape is preserved"],
      "evidence": ["loop-engineering-evidence", "TestCompleteTaskReportsNeedsInputWithoutCompletingAssignment"],
      "expires_after": "24h",
      "fails_when": ["clarification output completes assignment", "needs_input metadata missing", "endpoint shape changes"],
      "evidence_graph": {
        "observation": "Intent-oriented work can make a provider ask a clarification question and exit successfully.",
        "hypothesis": "The daemon can treat the clarification as waiting-for-user metadata while preserving the existing SaaS event contract.",
        "change": "saasplane maps canonical clarification result text to assignment_state_updated/running with assignment_result_status=needs_input.",
        "verifier": "TestCompleteTaskReportsNeedsInputWithoutCompletingAssignment",
        "evidence": "intent-clarification-result loop evidence",
        "decision": "clarification-only outputs remain conversational rather than terminal completion.",
        "next_loop": "exercise the same conversation through live SaaS v3 thread history."
      }
    }
  ],
