  "workflows": [
    {
      "id": "agentbridge-root",
      "workflow": ".github/workflows/agentbridge-root.yml",
      "evidence_artifact": "agentbridge-root-evidence",
      "required_fragments": ["Verify agentbridge stays provider neutral", "go list -f '{{range .Imports}}{{println .}}{{end}}' ./internal/agentbridge", "go test ./internal/agentbridge -run 'Reduce|Telemetry|FilterBlockedArgs|Semantic|States|Lifecycle' -count=1"]
    },
    {
      "id": "bridge-detectutil",
      "workflow": ".github/workflows/bridge-detectutil.yml",
      "evidence_artifact": "bridge-detectutil-evidence",
      "required_fragments": ["Verify bridge/detectutil stay provider neutral", "go list -f '{{range .Imports}}{{println .}}{{end}}' ./internal/agentbridge/bridge ./internal/agentbridge/detectutil", "go test ./internal/agentbridge/bridge ./internal/agentbridge/detectutil ./internal/agentbridge/session ./internal/process -run 'New|Detect|Run|Cancel|ProtocolDriver|TempFiles|ResolveExecutable|VersionProbe' -count=1"]
    },
    {
      "id": "controlplane",
      "workflow": ".github/workflows/controlplane.yml",
      "evidence_artifact": "controlplane-evidence",
      "required_fragments": ["Verify controlplane root stays provider neutral", "go list -f '{{range .Imports}}{{println .}}{{end}}' ./internal/agentbridge/controlplane", "go test ./internal/agentbridge/controlplane -run 'TaskReportContext|MemorySource|MemoryReporter|FileReporter|FileQueueSource' -count=1"]
    },
    {
      "id": "event-ingestor",
      "workflow": ".github/workflows/event-ingestor.yml",
      "evidence_artifact": "event-ingestor-evidence",
      "required_fragments": ["Verify EventIngestor redaction/audit gate", "go test ./internal/policy ./internal/ir/ingest ./internal/workdir -run 'Redact|Secret|Ingest|RunEventSink|AppendEvents' -count=1"]
    },
    {
      "id": "mwsd-project",
      "workflow": ".github/workflows/mwsd-project.yml",
      "evidence_artifact": "mwsd-project-evidence",
      "required_fragments": ["Verify mwsd/project public boundary", "go test ./internal/mwsdbridge ./internal/project ./cmd/riido -count=1", "go build -o /tmp/riido-mwsd-check ./cmd/riido"]
    }
  ]
}
